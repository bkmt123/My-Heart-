let selectedSleepQ = { his: null, her: null };

function selectSleepQ(who, val, el){
  selectedSleepQ[who] = val;
  const grid = document.getElementById(`${who}-q-grid`);
  if(grid) grid.querySelectorAll('.sleep-q-btn').forEach(b => b.classList.remove('selected'));
  el.classList.add('selected');
}

function calcDuration(bed, wake){
  if(!bed || !wake) return null;
  const [bh,bm] = bed.split(':').map(Number);
  const [wh,wm] = wake.split(':').map(Number);
  let mins = (wh*60+wm) - (bh*60+bm);
  if(mins < 0) mins += 24*60;
  return mins;
}

function fmtDur(mins){
  if(mins == null || isNaN(mins)) return '—';
  const h = Math.floor(mins/60), m = mins%60;
  return m ? `${h}h ${m}m` : `${h}h`;
}

function updateSleepCalc(who){
  const bed  = document.getElementById(`sl-${who}-bed`)?.value;
  const wake = document.getElementById(`sl-${who}-wake`)?.value;
  const el   = document.getElementById(`sl-${who}-calc`);
  if(el) el.textContent = calcDuration(bed,wake) != null ? fmtDur(calcDuration(bed,wake)) : '';
}

function saveSleepGoal(){
  const bed  = document.getElementById('sl-goal-bed')?.value  || '22:00';
  const wake = document.getElementById('sl-goal-wake')?.value || '06:00';
  state.notes['sleep-goal-bed']  = bed;
  state.notes['sleep-goal-wake'] = wake;
  save();
  updateGoalDisplay();
}

function updateGoalDisplay(){
  const bed  = state.notes['sleep-goal-bed']  || '22:00';
  const wake = state.notes['sleep-goal-wake'] || '06:00';
  const dur  = calcDuration(bed, wake);
  const el   = document.getElementById('sl-goal-hrs');
  if(el && dur != null) el.textContent = `Goal: ${fmtDur(dur)} of sleep`;
  // Her side read-only display
  const hd = document.getElementById('sl-goal-display');
  if(hd) hd.textContent = dur != null ? `${bed} → ${wake} (${fmtDur(dur)})` : '—';
}

function logSleep(who){
  const bed  = document.getElementById(`sl-${who}-bed`)?.value;
  const wake = document.getElementById(`sl-${who}-wake`)?.value;
  if(!bed || !wake){ alert('Please set both bedtime and wake time.'); return; }
  const dur  = calcDuration(bed, wake);
  const note = document.getElementById(`sl-${who}-note-inp`)?.value.trim() || '';
  const key  = who === 'his' ? 'hisSleep' : 'herSleep';
  state[key] = state[key] || [];
  state[key].unshift({ id: Date.now(), date: todayKey(), bed, wake, dur, quality: selectedSleepQ[who]||3, note });
  if(state[key].length > 60) state[key] = state[key].slice(0,60);
  // Reset form
  selectedSleepQ[who] = null;
  const grid = document.getElementById(`${who}-q-grid`);
  if(grid) grid.querySelectorAll('.sleep-q-btn').forEach(b => b.classList.remove('selected'));
  const ni = document.getElementById(`sl-${who}-note-inp`);
  if(ni) ni.value = '';
  save(); renderSleep();
}

function deleteSleepEntry(who, id){
  const key = who === 'his' ? 'hisSleep' : 'herSleep';
  state[key] = (state[key]||[]).filter(e => e.id !== id);
  save(); renderSleep();
}

const Q_COLORS = {1:'#C4868A',2:'#C8A96E',3:'#8A8FA8',4:'#7BA68A',5:'#6B9FC4'};
const Q_LABELS = {1:'Poor',2:'Fair',3:'Okay',4:'Good',5:'Great'};
const Q_ICONS  = {1:'😫',2:'😔',3:'😐',4:'😊',5:'😴'};

function sleepStats(log){
  const week = (log||[]).slice(0,7);
  const avg  = week.length ? Math.round(week.reduce((s,e)=>s+(e.dur||0),0)/week.length) : null;
  let streak = 0;
  for(const e of (log||[])){ if((e.quality||0)>=4||(e.dur||0)>=420) streak++; else break; }
  return { avg, last: (log||[])[0]?.dur ?? null, streak };
}

function renderSleep(){
  const his = state.hisSleep || [];
  const her = state.herSleep || [];

  // Stats
  const hs = sleepStats(his), hr = sleepStats(her);
  document.getElementById('sl-his-avg').textContent    = hs.avg  ? fmtDur(hs.avg)  : '—';
  document.getElementById('sl-his-last').textContent   = hs.last != null ? fmtDur(hs.last) : '—';
  document.getElementById('sl-his-streak').textContent = hs.streak;
  document.getElementById('sl-her-avg').textContent    = hr.avg  ? fmtDur(hr.avg)  : '—';
  document.getElementById('sl-her-last').textContent   = hr.last != null ? fmtDur(hr.last) : '—';
  document.getElementById('sl-her-streak').textContent = hr.streak;

  // Goal pickers
  const gb = document.getElementById('sl-goal-bed');
  const gw = document.getElementById('sl-goal-wake');
  if(gb && state.notes['sleep-goal-bed'])  gb.value = state.notes['sleep-goal-bed'];
  if(gw && state.notes['sleep-goal-wake']) gw.value = state.notes['sleep-goal-wake'];
  updateGoalDisplay();

  // Notes — both directions
  const snh  = document.getElementById('sleep-note-his');
  const snhv = document.getElementById('sleep-note-his-view');
  const snr  = document.getElementById('sleep-note-her');
  const snrv = document.getElementById('sleep-note-her-view');
  if(snh  && state.notes['sleep-note-his']) snh.value  = state.notes['sleep-note-his'];
  if(snhv) snhv.textContent = state.notes['sleep-note-his'] || '—';
  if(snr  && state.notes['sleep-note-her']) snr.value  = state.notes['sleep-note-her'];
  if(snrv) snrv.textContent = state.notes['sleep-note-her'] || '—';

  // Comparison log
  const list = document.getElementById('sleep-compare-list');
  if(!list) return;

  // Build a unified date list from both logs
  const allDates = [...new Set([...his.map(e=>e.date), ...her.map(e=>e.date)])].sort().reverse();
  if(!allDates.length){
    list.innerHTML = '<div style="color:var(--text-dim);font-size:13px;padding:10px 0;">No sleep logged yet — start tonight.</div>';
    return;
  }

  list.innerHTML = allDates.slice(0,14).map(date => {
    const h = his.find(e=>e.date===date);
    const r = her.find(e=>e.date===date);
    const d = new Date(date+'T12:00:00');
    const label = d.toLocaleDateString('en-US',{weekday:'short',month:'short',day:'numeric'});
    const maxDur = 480; // 8hrs reference

    const hisBar = h ? `<div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">
      <span style="font-size:11px;color:var(--gold);min-width:20px;">👤</span>
      <div style="flex:1;background:var(--border);border-radius:99px;height:6px;overflow:hidden;">
        <div style="width:${Math.min(100,Math.round(((h.dur||0)/maxDur)*100))}%;height:100%;border-radius:99px;background:var(--gold);"></div>
      </div>
      <span style="font-size:12px;color:var(--gold);min-width:40px;">${fmtDur(h.dur)}</span>
      <span style="font-size:14px;" title="${Q_LABELS[h.quality]||''}">${Q_ICONS[h.quality]||''}</span>
      ${h.note?`<span style="font-size:11px;color:var(--text-dim);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${h.note}</span>`:''}
      <button class="gift-del-btn" onclick="deleteSleepEntry('his',${h.id})">✕</button>
    </div>` : `<div style="font-size:11px;color:var(--muted);margin-bottom:6px;">👤 Not logged</div>`;

    const herBar = r ? `<div style="display:flex;align-items:center;gap:8px;">
      <span style="font-size:11px;color:var(--rose);min-width:20px;">🌸</span>
      <div style="flex:1;background:var(--border);border-radius:99px;height:6px;overflow:hidden;">
        <div style="width:${Math.min(100,Math.round(((r.dur||0)/maxDur)*100))}%;height:100%;border-radius:99px;background:var(--rose);"></div>
      </div>
      <span style="font-size:12px;color:var(--rose);min-width:40px;">${fmtDur(r.dur)}</span>
      <span style="font-size:14px;" title="${Q_LABELS[r.quality]||''}">${Q_ICONS[r.quality]||''}</span>
      ${r.note?`<span style="font-size:11px;color:var(--text-dim);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${r.note}</span>`:''}
      <button class="gift-del-btn" onclick="deleteSleepEntry('her',${r.id})">✕</button>
    </div>` : `<div style="font-size:11px;color:var(--muted);">🌸 Not logged</div>`;

    return `<div style="padding:12px 0;border-bottom:1px solid var(--border);">
      <div style="font-size:11px;color:var(--muted);margin-bottom:8px;font-weight:600;">${label}</div>
      ${hisBar}${herBar}
    </div>`;
  }).join('');
}

document.addEventListener('DOMContentLoaded', ()=>{
  ['his','her'].forEach(who => {
    document.getElementById(`sl-${who}-bed`)?.addEventListener('input',  ()=>updateSleepCalc(who));
    document.getElementById(`sl-${who}-wake`)?.addEventListener('input', ()=>updateSleepCalc(who));
  });
  updateSleepCalc('his');
  updateSleepCalc('her');
});
// ══════════════════════════════════════════════════════

</script>
