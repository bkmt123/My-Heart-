<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Our Dashboard — A Husband's Promise</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400;1,600&family=Amiri:ital,wght@0,400;0,700;1,400&family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{
  --bg:#0B0E14;--surface:#111520;--card:#161B27;--border:#222840;
  --gold:#C8A96E;--gold-soft:#E8D5A8;--sage:#7BA68A;--rose:#C4868A;--sky:#6B9FC4;--purple:#A478C8;
  --muted:#4A5270;--text:#EAE8E0;--text-dim:#8A8FA8;
  --display:'Cormorant Garamond',serif;--arabic:'Amiri',serif;--body:'Inter',sans-serif;
}
html{scroll-behavior:smooth;}
body{background:var(--bg);color:var(--text);font-family:var(--body);min-height:100vh;font-size:14px;line-height:1.6;}

/* ── TOP BAR ── */
.top-bar{height:4px;background:linear-gradient(90deg,transparent,var(--gold) 20%,var(--gold-soft) 50%,var(--gold) 80%,transparent);opacity:.6;}

/* ── HEADER ── */
header{position:relative;padding:32px 36px 24px;border-bottom:1px solid var(--border);overflow:hidden;}
.header-bg{position:absolute;inset:0;background-image:radial-gradient(circle at 80% 50%,rgba(200,169,110,.06) 0%,transparent 60%),radial-gradient(circle at 20% 50%,rgba(123,166,138,.04) 0%,transparent 50%);pointer-events:none;}
.star-cluster{position:absolute;right:200px;top:50%;transform:translateY(-50%);opacity:.15;display:flex;gap:10px;align-items:center;}
.star-8{width:48px;height:48px;background:conic-gradient(var(--gold) 0deg 45deg,transparent 45deg 90deg,var(--gold) 90deg 135deg,transparent 135deg 180deg,var(--gold) 180deg 225deg,transparent 225deg 270deg,var(--gold) 270deg 315deg,transparent 315deg 360deg);clip-path:polygon(50% 0%,61% 35%,98% 35%,68% 57%,79% 91%,50% 70%,21% 91%,32% 57%,2% 35%,39% 35%);}
.star-8.sm{width:30px;height:30px;}.star-8.xs{width:18px;height:18px;}
.header-content{position:relative;}
.header-bismillah{font-family:var(--arabic);font-size:17px;color:var(--gold);margin-bottom:7px;opacity:.85;}
.header-title{font-family:var(--display);font-size:33px;font-weight:600;letter-spacing:-.01em;line-height:1.1;}
.header-title em{color:var(--gold);font-style:italic;}
.header-sub{font-family:var(--display);font-style:italic;font-size:13px;color:var(--text-dim);margin-top:5px;}
.header-meta{position:absolute;right:0;top:0;text-align:right;}
#live-date{color:var(--gold);font-size:12px;font-family:var(--body);}
#day-count{font-family:var(--display);font-style:italic;font-size:13px;color:var(--gold-soft);margin-top:3px;}

/* ── MODE SWITCHER ── */
.mode-bar{background:var(--surface);border-bottom:1px solid var(--border);padding:12px 36px;display:flex;align-items:center;gap:12px;flex-wrap:wrap;}
.mode-label{font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);}
.mode-toggle{display:flex;background:var(--card);border:1px solid var(--border);border-radius:8px;overflow:hidden;}
.mode-btn{padding:7px 20px;font-size:12px;font-weight:600;border:none;background:transparent;color:var(--text-dim);cursor:pointer;transition:all .2s;display:flex;align-items:center;gap:6px;}
.mode-btn.active-his{background:var(--gold);color:#0B0E14;}
.mode-btn.active-her{background:var(--rose);color:#fff;}
.mode-indicator{margin-left:auto;font-family:var(--display);font-style:italic;font-size:14px;}
.mode-indicator.his{color:var(--gold);}
.mode-indicator.her{color:var(--rose);}
/* ── SYNC BADGE ── */
.sync-area{margin-left:auto;display:flex;align-items:center;gap:10px;}
#sync-badge{font-size:11px;display:flex;align-items:center;gap:5px;color:var(--muted);transition:color .3s;}
#sync-badge span{font-family:var(--body);}
.sync-gear{background:transparent;border:1px solid var(--border);border-radius:6px;padding:5px 9px;font-size:13px;color:var(--muted);cursor:pointer;transition:all .2s;}
.sync-gear:hover{border-color:var(--gold);color:var(--gold);}
/* ── SYNC MODAL ── */
.sync-modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:200;align-items:center;justify-content:center;}
.sync-modal{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:28px;width:min(480px,92vw);position:relative;}
.sync-modal h3{font-family:var(--display);font-size:22px;font-weight:600;margin-bottom:4px;}
.sync-modal h3 em{color:var(--gold);font-style:italic;}
.sync-modal-sub{font-size:12px;color:var(--text-dim);margin-bottom:20px;line-height:1.6;}
.sync-field{margin-bottom:14px;}
.sync-field label{display:block;font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-bottom:6px;}
.sync-guide{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:14px 16px;margin-bottom:18px;font-size:12px;color:var(--text-dim);line-height:1.8;}
.sync-guide strong{color:var(--gold-soft);}
.sync-guide code{background:var(--bg);padding:1px 5px;border-radius:4px;font-family:monospace;color:var(--text);}
.sync-modal-footer{display:flex;gap:10px;justify-content:flex-end;flex-wrap:wrap;border-top:1px solid var(--border);padding-top:16px;margin-top:4px;}

/* ── NAV ── */
nav{display:flex;gap:2px;padding:10px 36px 0;border-bottom:1px solid var(--border);overflow-x:auto;scrollbar-width:none;background:var(--surface);}
nav::-webkit-scrollbar{display:none;}
.tab{font-family:var(--body);font-size:12px;font-weight:500;padding:8px 16px 10px;border:none;background:transparent;color:var(--muted);cursor:pointer;border-bottom:2px solid transparent;transition:color .15s,border-color .15s;white-space:nowrap;}
.tab:hover{color:var(--text);}
.tab.active{color:var(--gold);border-bottom-color:var(--gold);}
.tab-locked{display:flex;align-items:center;gap:5px;}
.lock-icon{font-size:11px;opacity:.6;}

/* ── MAIN ── */
main{padding:28px 36px;max-width:1200px;}
.panel{display:none;}.panel.active{display:block;}

/* ── HER VIEW badge ── */
.her-only{display:none;}
.her-mode .her-only{display:block;}
.his-only{display:block;}
.her-mode .his-only{display:none;}

/* ── SECTION HEAD ── */
.section-head{margin-bottom:20px;}
.section-head h2{font-family:var(--display);font-size:26px;font-weight:600;}
.section-head h2 em{color:var(--gold);font-style:italic;}
.section-eyebrow{font-size:10px;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);margin-bottom:6px;}

/* ── GRIDS ── */
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:18px;}
.grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;}
.grid-4{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;}
@media(max-width:900px){.grid-3,.grid-4{grid-template-columns:1fr 1fr;}}
@media(max-width:600px){
  .grid-2,.grid-3,.grid-4{grid-template-columns:1fr;}
  main{padding:18px 14px;}header{padding:22px 14px 18px;}
  nav,.mode-bar{padding-left:14px;padding-right:14px;}
  .header-title{font-size:24px;}.star-cluster{display:none;}
}

/* ── CARD ── */
.card{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:20px;}
.card-eyebrow{font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:var(--muted);margin-bottom:12px;}
.card-accent-top{border-top:2px solid var(--gold);}
.card-accent-sage{border-top:2px solid var(--sage);}
.card-accent-rose{border-top:2px solid var(--rose);}
.card-accent-sky{border-top:2px solid var(--sky);}

/* ── STAT ── */
.stat-block{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:16px 20px;display:flex;flex-direction:column;gap:5px;}
.stat-val{font-family:var(--display);font-size:34px;font-weight:600;line-height:1;}
.stat-label{font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--text-dim);}
.c-gold{color:var(--gold);}.c-sage{color:var(--sage);}.c-rose{color:var(--rose);}.c-sky{color:var(--sky);}

/* ── INPUTS ── */
.inp{background:var(--surface);border:1px solid var(--border);border-radius:7px;padding:9px 13px;font-family:var(--body);font-size:13px;color:var(--text);outline:none;transition:border-color .15s;width:100%;}
.inp:focus{border-color:var(--gold);}
.inp::placeholder{color:var(--muted);}
select.inp{cursor:pointer;}
textarea.inp{resize:vertical;min-height:80px;line-height:1.6;}
.note-area{background:var(--surface);border:1px solid var(--border);border-radius:7px;padding:10px 13px;font-family:var(--display);font-style:italic;font-size:13px;color:var(--text);resize:vertical;min-height:90px;width:100%;outline:none;line-height:1.7;transition:border-color .15s;}
.note-area:focus{border-color:var(--gold);}
.note-area::placeholder{color:var(--muted);}

/* ── BUTTONS ── */
.btn{background:var(--gold);color:#0B0E14;border:none;border-radius:7px;padding:8px 18px;font-size:13px;font-weight:600;cursor:pointer;transition:opacity .15s;white-space:nowrap;}
.btn:hover{opacity:.85;}
.btn-ghost{background:transparent;border:1px solid var(--border);color:var(--text-dim);border-radius:7px;padding:7px 14px;font-size:12px;cursor:pointer;transition:all .15s;}
.btn-ghost:hover{border-color:var(--gold);color:var(--gold);}
.btn-rose{background:var(--rose);color:#fff;}
.btn-sage{background:var(--sage);color:#0B0E14;}
.btn-sm{padding:5px 12px;font-size:11px;}

/* ── LOVE LANGUAGES ── */
.ll-row{display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid var(--border);}
.ll-row:last-child{border-bottom:none;}
.ll-icon{font-size:18px;min-width:28px;text-align:center;}
.ll-name{flex:1;font-family:var(--display);font-size:15px;font-weight:600;}
.ll-bar-track{height:5px;background:var(--border);border-radius:99px;overflow:hidden;margin-top:4px;}
.ll-bar-fill{height:100%;border-radius:99px;transition:width .5s ease;}
.ll-score{font-size:11px;color:var(--text-dim);min-width:24px;text-align:right;}
.ll-btn{font-size:15px;background:none;border:none;cursor:pointer;opacity:.5;transition:opacity .15s,transform .1s;}
.ll-btn:hover{opacity:1;transform:scale(1.2);}

/* ── PRAYER ── */
.prayer-row{display:flex;align-items:center;gap:10px;padding:9px 0;border-bottom:1px solid var(--border);}
.prayer-row:last-child{border-bottom:none;}
.prayer-name{font-family:var(--display);font-size:14px;font-weight:600;flex:1;}
.prayer-check{width:20px;height:20px;border:2px solid var(--border);border-radius:5px;cursor:pointer;flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:all .15s;}
.prayer-check.done{background:var(--sage);border-color:var(--sage);}
.prayer-check.done::after{content:'✓';font-size:11px;color:#0B0E14;font-weight:700;}
.prayer-note{font-size:11px;color:var(--muted);font-style:italic;}

/* ── MOOD ── */
.mood-grid{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:14px;}
.mood-btn{font-size:20px;background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:8px 12px;cursor:pointer;transition:all .15s;}
.mood-btn:hover{border-color:var(--gold);transform:scale(1.05);}
.mood-btn.selected{border-color:var(--rose);background:rgba(196,134,138,.12);}
.mood-label{font-size:9px;display:block;text-align:center;color:var(--text-dim);margin-top:2px;}
.mood-log-item{display:flex;align-items:center;gap:10px;padding:7px 0;border-bottom:1px solid var(--border);font-size:13px;}
.mood-log-item:last-child{border-bottom:none;}
.mood-log-date{font-size:11px;color:var(--muted);min-width:70px;}

/* ── DATE NIGHTS ── */
.date-card{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:14px;margin-bottom:10px;animation:fadeIn .2s ease;}
.date-title-el{font-family:var(--display);font-size:15px;font-weight:600;margin-bottom:2px;}
.date-note-el{font-size:12px;color:var(--text-dim);}
.date-status-badge{font-size:10px;letter-spacing:.08em;padding:2px 8px;border-radius:3px;margin-left:auto;flex-shrink:0;}
.ds-idea{background:rgba(74,82,112,.2);color:var(--muted);}
.ds-planned{background:rgba(107,159,196,.12);color:var(--sky);}
.ds-done{background:rgba(123,166,138,.12);color:var(--sage);}
.date-footer{display:flex;gap:8px;margin-top:10px;align-items:center;}
.date-when-el{font-size:11px;color:var(--muted);flex:1;font-style:italic;}

/* ── GIFT ── */
.gift-item{display:flex;align-items:center;gap:10px;padding:9px 0;border-bottom:1px solid var(--border);animation:fadeIn .2s ease;}
.gift-item:last-child{border-bottom:none;}
.gift-name{flex:1;font-size:13px;}
.gift-bought{text-decoration:line-through;color:var(--muted);}
.gift-cat-badge{font-size:10px;padding:2px 8px;border-radius:3px;}
.gift-check-btn{background:none;border:none;cursor:pointer;font-size:14px;opacity:.5;transition:opacity .15s;}
.gift-check-btn:hover{opacity:1;}
.gift-del-btn{background:none;border:none;color:var(--muted);cursor:pointer;font-size:13px;}
.gift-del-btn:hover{color:var(--rose);}

/* ── MILESTONE ── */
.ml-row{display:flex;gap:14px;padding:12px 0;border-bottom:1px solid var(--border);align-items:flex-start;}
.ml-row:last-child{border-bottom:none;}
.ml-dot-col{display:flex;flex-direction:column;align-items:center;gap:4px;}
.ml-dot{width:12px;height:12px;border-radius:50%;border:2px solid var(--border);flex-shrink:0;margin-top:3px;}
.ml-dot.done{background:var(--sage);border-color:var(--sage);}
.ml-dot.active{background:var(--gold);border-color:var(--gold);}
.ml-dot.future{border-color:var(--muted);}
.ml-vline{width:1px;flex:1;background:var(--border);min-height:14px;}
.ml-title-el{font-family:var(--display);font-size:14px;font-weight:600;margin-bottom:2px;}
.ml-date-el{font-size:10px;color:var(--muted);letter-spacing:.08em;margin-bottom:3px;}
.ml-note-el{font-size:12px;color:var(--text-dim);}

/* ── AYAH BOX ── */
.ayah-box{background:linear-gradient(135deg,rgba(200,169,110,.07),rgba(123,166,138,.05));border:1px solid rgba(200,169,110,.2);border-radius:10px;padding:22px 24px;text-align:center;}
.ayah-arabic{font-family:var(--arabic);font-size:22px;line-height:1.8;color:var(--gold-soft);direction:rtl;margin-bottom:12px;}
.ayah-trans{font-family:var(--display);font-style:italic;font-size:14px;color:var(--text-dim);line-height:1.7;}
.ayah-ref{font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-top:10px;}

/* ── REMINDER BANNER ── */
.reminder-banner{background:linear-gradient(90deg,rgba(200,169,110,.1),rgba(123,166,138,.08));border:1px solid rgba(200,169,110,.25);border-radius:10px;padding:14px 18px;display:flex;align-items:center;gap:12px;margin-bottom:20px;}
.reminder-text{font-family:var(--display);font-style:italic;font-size:15px;color:var(--gold-soft);}

/* ── HER MESSAGE BOX ── */
.her-message-box{background:linear-gradient(135deg,rgba(196,134,138,.08),rgba(164,120,200,.05));border:1px solid rgba(196,134,138,.25);border-radius:10px;padding:20px 24px;margin-bottom:20px;}
.her-message-title{font-family:var(--display);font-size:20px;font-weight:600;color:var(--rose);margin-bottom:8px;}
.her-message-body{font-family:var(--display);font-style:italic;font-size:14px;color:var(--text-dim);line-height:1.8;}

/* ── LOCKED SCREEN ── */
.lock-screen{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:60px 20px;text-align:center;}
.lock-icon-big{font-size:56px;margin-bottom:20px;animation:gentlePulse 2.5s ease-in-out infinite;}
.lock-title{font-family:var(--display);font-size:28px;font-weight:600;color:var(--gold);margin-bottom:8px;}
.lock-sub{font-family:var(--display);font-style:italic;font-size:14px;color:var(--text-dim);margin-bottom:28px;max-width:360px;}
.pin-display{display:flex;gap:10px;justify-content:center;margin-bottom:20px;}
.pin-dot{width:14px;height:14px;border-radius:50%;border:2px solid var(--border);transition:all .2s;}
.pin-dot.filled{background:var(--gold);border-color:var(--gold);}
.pin-pad{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;max-width:240px;margin:0 auto;}
.pin-key{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:16px;font-family:var(--display);font-size:22px;font-weight:600;cursor:pointer;transition:all .15s;color:var(--text);}
.pin-key:hover{border-color:var(--gold);color:var(--gold);background:rgba(200,169,110,.08);}
.pin-key:active{transform:scale(.95);}
.pin-key.zero{grid-column:2;}
.pin-key.back{font-size:16px;color:var(--muted);}
.pin-key.back:hover{border-color:var(--rose);color:var(--rose);}
.pin-error{color:var(--rose);font-size:12px;margin-top:10px;min-height:18px;font-family:var(--body);}

/* ── SURPRISE CARD ── */
.surprise-card{background:var(--surface);border:1px solid rgba(200,169,110,.2);border-radius:10px;padding:16px;margin-bottom:12px;animation:fadeIn .25s ease;position:relative;overflow:hidden;}
.surprise-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;}
.sc-date::before{background:var(--gold);}
.sc-gift::before{background:var(--rose);}
.sc-exp::before{background:var(--purple);}
.surprise-type{font-size:10px;letter-spacing:.12em;text-transform:uppercase;margin-bottom:6px;}
.surprise-title-el{font-family:var(--display);font-size:16px;font-weight:600;margin-bottom:4px;}
.surprise-detail{font-size:12px;color:var(--text-dim);line-height:1.6;margin-bottom:8px;}
.surprise-footer{display:flex;align-items:center;gap:8px;padding-top:8px;border-top:1px solid var(--border);}
.surprise-when{font-size:11px;color:var(--muted);flex:1;font-style:italic;}
.surprise-status-badge{font-size:10px;padding:2px 8px;border-radius:3px;letter-spacing:.06em;}
.ss-planning{background:rgba(107,159,196,.12);color:var(--sky);}
.ss-ready{background:rgba(200,169,110,.12);color:var(--gold);}
.ss-done{background:rgba(123,166,138,.12);color:var(--sage);}

/* ── DUA SECTION ── */
.dua-item{padding:12px 0;border-bottom:1px solid var(--border);}
.dua-item:last-child{border-bottom:none;}
.dua-title-el{font-family:var(--display);font-size:14px;font-weight:600;margin-bottom:3px;}
.dua-body{font-size:13px;color:var(--text-dim);line-height:1.6;}

/* ── MISC ── */
.row{display:flex;gap:8px;align-items:center;flex-wrap:wrap;}
.col{display:flex;flex-direction:column;gap:14px;}
.mt8{margin-top:8px;}.mt12{margin-top:12px;}.mt16{margin-top:16px;}.mt20{margin-top:20px;}
.mb12{margin-bottom:12px;}.mb16{margin-bottom:16px;}.mb20{margin-bottom:20px;}
.divider{margin:18px 0;border:none;border-top:1px solid var(--border);}
@keyframes fadeIn{from{opacity:0;transform:translateY(5px);}to{opacity:1;transform:none;}}
@keyframes gentlePulse{0%,100%{opacity:.6;}50%{opacity:1;}}
@keyframes shake{0%,100%{transform:translateX(0);}25%{transform:translateX(-6px);}75%{transform:translateX(6px);}}
.shake{animation:shake .35s ease;}

/* ── MODAL ── */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.78);z-index:100;display:flex;align-items:center;justify-content:center;padding:16px;}
.modal{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:26px;width:100%;max-width:440px;}
.modal h3{font-family:var(--display);font-size:22px;font-weight:600;margin-bottom:18px;color:var(--gold);}
.field{display:flex;flex-direction:column;gap:6px;margin-bottom:13px;}
.field label{font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--text-dim);}
.modal-footer{display:flex;gap:8px;justify-content:flex-end;margin-top:16px;}

/* ── HER SECTION TINT ── */
.her-mode .card-accent-top{border-top-color:var(--rose);}
.her-mode .tab.active{color:var(--rose);border-bottom-color:var(--rose);}
.her-mode .btn{background:var(--rose);color:#fff;}
.her-mode .inp:focus,.her-mode .note-area:focus{border-color:var(--rose);}

/* ── SLEEP TRACKER ── */
.sleep-quality-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:8px;margin:12px 0;}
.sleep-q-btn{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:10px 4px;text-align:center;cursor:pointer;transition:all .2s;font-size:11px;color:var(--muted);}
.sleep-q-btn span{display:block;font-size:22px;margin-bottom:4px;}
.sleep-q-btn:hover{border-color:var(--sky);color:var(--text);}
.sleep-q-btn.selected{border-color:var(--sky);background:rgba(107,159,196,.12);color:var(--sky);}
.sleep-log-item{display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid var(--border);font-size:13px;}
.sleep-log-item:last-child{border-bottom:none;}
.sleep-log-date{font-size:11px;color:var(--muted);min-width:70px;}
.sleep-duration{font-family:var(--display);font-size:18px;color:var(--sky);min-width:50px;}
.sleep-quality-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.sleep-bar-wrap{flex:1;background:var(--border);border-radius:99px;height:5px;overflow:hidden;}
.sleep-bar-fill{height:100%;border-radius:99px;background:linear-gradient(90deg,var(--rose),var(--sky));transition:width .4s;}
.sleep-stat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:20px;}
.sleep-stat{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:16px;text-align:center;}
.sleep-stat-val{font-family:var(--display);font-size:26px;color:var(--sky);}
.sleep-stat-label{font-size:11px;color:var(--muted);letter-spacing:.08em;text-transform:uppercase;margin-top:3px;}
.bedtime-row{display:flex;align-items:center;gap:12px;flex-wrap:wrap;}
.time-inp{background:var(--card);border:1px solid var(--border);border-radius:8px;padding:8px 12px;color:var(--text);font-size:14px;font-family:var(--body);width:130px;}
.time-inp:focus{outline:none;border-color:var(--sky);}

/* ── MILESTONES ── */
.ml-status-btn{font-size:10px;padding:2px 8px;border-radius:99px;border:1px solid var(--border);background:transparent;color:var(--muted);cursor:pointer;margin-top:4px;white-space:nowrap;}
.ml-status-btn:hover{border-color:var(--gold);color:var(--gold);}
.ml-del-btn{font-size:11px;background:transparent;border:none;color:var(--muted);cursor:pointer;padding:2px 6px;border-radius:4px;}
.ml-del-btn:hover{color:var(--rose);}
.ml-add-form{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:14px;margin-top:14px;}
.ml-date-el{font-size:12px;color:var(--muted);margin-bottom:4px;}
.ml-note-el{font-size:13px;color:var(--text-dim);line-height:1.6;}
</style>
</head>
