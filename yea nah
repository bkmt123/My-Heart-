// ── AIRTABLE CONFIG ──────────────────────────────────────────────────────────
// Replace these three values with your own. See setup guide below.
const AT_CONFIG = {
  apiKey:  localStorage.getItem('at_api_key')  || '',   // Airtable Personal Access Token
  baseId:  localStorage.getItem('at_base_id')  || '',   // e.g. appXXXXXXXXXXXXXX
  tableId: localStorage.getItem('at_table_id') || '',   // e.g. tblXXXXXXXXXXXXXX or table name
  recordId:localStorage.getItem('at_record_id')|| '',   // filled automatically after first push
};

let syncStatus = 'idle'; // idle | syncing | saved | error
let syncTimeout = null;

function atConfigured(){
  return AT_CONFIG.apiKey && AT_CONFIG.baseId && AT_CONFIG.tableId;
}

function atUrl(recordId){
  const base = `https://api.airtable.com/v0/${AT_CONFIG.baseId}/${encodeURIComponent(AT_CONFIG.tableId)}`;
  return recordId ? `${base}/${recordId}` : base;
}

function atHeaders(){
  return { 'Authorization':`Bearer ${AT_CONFIG.apiKey}`, 'Content-Type':'application/json' };
}

function setSyncBadge(status, msg=''){
  syncStatus = status;
  const badge = document.getElementById('sync-badge');
  if(!badge) return;
  const map = {
    idle:    ['⚪','Not configured','#4A5270'],
    syncing: ['🔄','Syncing…','#C8A96E'],
    saved:   ['🟢','Synced','#7BA68A'],
    error:   ['🔴', msg||'Sync error','#C4868A'],
    offline: ['🟡','Offline — saved locally','#C8A96E'],
  };
  const [icon, label, color] = map[status] || map.idle;
  badge.innerHTML = `${icon} <span>${label}</span>`;
  badge.style.color = color;
}

// Pull latest state from Airtable on load
async function syncPull(){
  if(!atConfigured()) return;
  setSyncBadge('syncing');
  try {
    let url, res, data;
    if(AT_CONFIG.recordId){
      // Fetch known record directly
      res = await fetch(atUrl(AT_CONFIG.recordId), { headers: atHeaders() });
      data = await res.json();
      if(data.error){ throw new Error(data.error.message); }
      const remote = JSON.parse(data.fields.StateJSON || '{}');
      // Merge: remote wins on everything except mode (keep local mode preference)
      const localMode = state.mode;
      Object.assign(state, remote);
      state.mode = localMode;
    } else {
      // First time — search for existing record for this dashboard
      res = await fetch(atUrl() + '?maxRecords=1&filterByFormula={DashboardKey}="wife-dashboard-v2"', { headers: atHeaders() });
      data = await res.json();
      if(data.error){ throw new Error(data.error.message); }
      if(data.records && data.records.length > 0){
        AT_CONFIG.recordId = data.records[0].id;
        localStorage.setItem('at_record_id', AT_CONFIG.recordId);
        const remote = JSON.parse(data.records[0].fields.StateJSON || '{}');
        const localMode = state.mode;
        Object.assign(state, remote);
        state.mode = localMode;
      }
      // else: no record yet — will be created on first push
    }
    setSyncBadge('saved');
  } catch(e){
    console.warn('Airtable pull failed:', e);
    setSyncBadge(navigator.onLine ? 'error' : 'offline', e.message);
  }
}

// Push state to Airtable (debounced so rapid typing doesn't flood API)
function schedulePush(){
  clearTimeout(syncTimeout);
  syncTimeout = setTimeout(syncPush, 1500);
}

async function syncPush(){
  if(!atConfigured()){ return; }
  setSyncBadge('syncing');
  // Strip surprises from the payload — they live only in localStorage for privacy
  const payload = { ...state };
  // StateJSON field holds the entire state; DashboardKey is used to find the record
  const fields = { DashboardKey: 'wife-dashboard-v2', StateJSON: JSON.stringify(payload) };
  try {
    let res, data;
    if(AT_CONFIG.recordId){
      res = await fetch(atUrl(AT_CONFIG.recordId), {
        method:'PATCH', headers: atHeaders(), body: JSON.stringify({ fields })
      });
    } else {
      res = await fetch(atUrl(), {
        method:'POST', headers: atHeaders(), body: JSON.stringify({ fields })
      });
    }
    data = await res.json();
    if(data.error){ throw new Error(data.error.message); }
    if(!AT_CONFIG.recordId && data.id){
      AT_CONFIG.recordId = data.id;
      localStorage.setItem('at_record_id', data.id);
    }
    setSyncBadge('saved');
  } catch(e){
    console.warn('Airtable push failed:', e);
    setSyncBadge(navigator.onLine ? 'error' : 'offline', e.message);
  }
}

